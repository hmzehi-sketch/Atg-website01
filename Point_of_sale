      SB_URL + `/rest/v1/atg_users?username=eq.${encodeURIComponent(un)}&password=eq.${encodeURIComponent(pw)}&select=*`,
      {
        headers: {
          'apikey': SB_KEY,
          'Authorization': 'Bearer ' + SB_KEY
        }
      }
    );
    const users = await res.json();

    if (!users.length) {
      document.getElementById('g-err').classList.add('show');
      btn.textContent = '→ Sign In';
      btn.disabled = false;
      return;
    }

    const user = users[0];
    sessionStorage.setItem(ATG_SESSION, JSON.stringify({
      id: user.id, name: user.name,
      username: user.username, role: user.role
    }));
    document.getElementById('auth-guard').classList.remove('show');

  } catch(e) {
    document.getElementById('g-err').textContent = 'Connection error. Try again.';
    document.getElementById('g-err').classList.add('show');
    btn.textContent = '→ Sign In';
    btn.disabled = false;
  }
}
</script>

</body>
</html>
