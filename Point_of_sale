<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>ATG Field Research</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
--atg-dark:#0a1628;--atg-navy:#0f2044;--atg-blue:#1a3a6e;
--atg-gold:#c8960a;--atg-gold-light:#f0b429;--atg-gold-pale:#fef3d0;
--atg-white:#fff;--atg-off:#f7f8fa;--atg-border:#e2e6ed;
--atg-text:#1a2332;--atg-muted:#6b7a8d;
--atg-ok:#0d6e4a;--atg-ok-bg:#e6f4ee;--atg-err:#b91c1c;--atg-err-bg:#fef2f2;
--r:10px;--sh:0 2px 12px rgba(10,22,40,.08);
}

/* AUTH GUARD */
.auth-guard {
  display: none;
  position: fixed;
  inset: 0;
  background: #040D1A;
  z-index: 9999;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.auth-guard.show { display: flex; }
.guard-box {
  background: #071220;
  border: 0.5px solid #A07830;
  padding: 2.5rem 2rem;
  width: 100%;
  max-width: 380px;
  text-align: center;
}
.guard-logo {
  width: 48px; height: 48px;
  border: 1.5px solid #C9A84C;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: #C9A84C;
  margin: 0 auto 1.2rem;
}
.guard-title { font-size: 18px; font-weight: 500; color: #EEF2F8; margin-bottom: 4px; }
.guard-sub { font-size: 11px; color: #7A90B0; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1.8rem; }
.guard-field { margin-bottom: 1rem; text-align: left; }
.guard-field label { display: block; font-size: 11px; font-weight: 600; color: #7A90B0; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 5px; }
.guard-field input { width: 100%; padding: 10px 14px; background: #0C1A2E; border: 0.5px solid #132540; color: #EEF2F8; font-size: 13px; font-family: inherit; outline: none; direction: ltr; transition: border-color 0.2s; }
.guard-field input:focus { border-color: #C9A84C; }
.guard-err { font-size: 12px; color: #e05a5a; margin-bottom: 1rem; display: none; padding: 7px; background: rgba(224,90,90,0.08); border: 0.5px solid rgba(224,90,90,0.3); }
.guard-err.show { display: block; }
.guard-btn { width: 100%; background: #C9A84C; color: #040D1A; border: none; padding: 11px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.3rem; }
.guard-btn:hover { background: #E8C97A; }
.guard-back { margin-top: 1rem; font-size: 12px; color: #7A90B0; cursor: pointer; text-decoration: underline; }
.guard-back:hover { color: #C9A84C; }

*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Segoe UI",Tahoma,Arial,sans-serif;background:var(--atg-off);color:var(--atg-text);min-height:100vh;}
[dir=ltr]{direction:ltr;}

/* HEADER */
.hdr{background:var(--atg-dark);position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(0,0,0,.25);}
.hdr-in{max-width:780px;margin:0 auto;padding:11px 16px;display:flex;align-items:center;justify-content:space-between;gap:10px;}
.logo{display:flex;align-items:center;gap:10px;}
.lmark{width:40px;height:40px;background:var(--atg-gold);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:var(--atg-dark);letter-spacing:-1px;flex-shrink:0;}
.lname{font-size:14px;font-weight:700;color:#fff;}
.ltag{font-size:9px;color:var(--atg-gold-light);text-transform:uppercase;letter-spacing:.08em;}
.hdr-right{display:flex;align-items:center;gap:8px;}
.lang-btns{display:flex;gap:4px;}
.lb{padding:4px 9px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;border:1px solid rgba(255,255,255,.2);background:transparent;color:rgba(255,255,255,.6);transition:all .15s;}
.lb.active{background:var(--atg-gold);color:var(--atg-dark);border-color:var(--atg-gold);}
.hbadge{background:rgba(200,150,10,.18);border:1px solid rgba(200,150,10,.35);color:var(--atg-gold-light);font-size:10px;font-weight:600;padding:4px 9px;border-radius:20px;}

/* MAIN */
.main{max-width:780px;margin:0 auto;padding:18px 14px 40px;}

/* STEP BAR */
.sbar{display:flex;background:#fff;border:1px solid var(--atg-border);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);margin-bottom:20px;}
.si{flex:1;padding:10px 4px 8px;text-align:center;cursor:pointer;border-left:1px solid var(--atg-border);transition:all .2s;}
.si:last-child{border-left:none;}
[dir=ltr] .si{border-left:none;border-right:1px solid var(--atg-border);}
[dir=ltr] .si:last-child{border-right:none;}
.si.active{background:var(--atg-navy);}
.si.done{background:var(--atg-ok-bg);}
.snum{width:22px;height:22px;background:var(--atg-border);border-radius:50%;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 3px;color:var(--atg-muted);transition:all .2s;}
.si.active .snum{background:var(--atg-gold);color:var(--atg-dark);}
.si.done .snum{background:var(--atg-ok);color:#fff;}
.slbl{font-size:9px;color:var(--atg-muted);white-space:nowrap;}
.si.active .slbl{color:var(--atg-gold-light);font-weight:600;}
.si.done .slbl{color:var(--atg-ok);}

/* CARD */
.card{background:#fff;border:1px solid var(--atg-border);border-radius:var(--r);box-shadow:var(--sh);margin-bottom:14px;overflow:hidden;}
.ch{background:var(--atg-navy);padding:13px 16px;display:flex;align-items:center;gap:10px;}
.ci{width:32px;height:32px;background:rgba(200,150,10,.2);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.ct{font-size:13px;font-weight:600;color:#fff;}
.cs{font-size:10px;color:rgba(255,255,255,.45);margin-top:1px;}
.cb{padding:16px;}

/* FIELDS */
.f{margin-bottom:13px;}
.f:last-child{margin-bottom:0;}
.f label{display:block;font-size:11px;font-weight:600;color:var(--atg-muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px;}
.f label .req{color:var(--atg-gold);margin-right:2px;}
.f input,.f select,.f textarea{width:100%;padding:9px 11px;border:1.5px solid var(--atg-border);border-radius:8px;font-size:13px;color:var(--atg-text);background:#fff;font-family:inherit;outline:none;transition:border-color .15s,box-shadow .15s;direction:inherit;}
.f input:focus,.f select:focus,.f textarea:focus{border-color:var(--atg-gold);box-shadow:0 0 0 3px rgba(200,150,10,.12);}
.f textarea{min-height:76px;resize:vertical;line-height:1.6;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}

/* DATETIME ROW */
.dtrow{display:grid;grid-template-columns:1fr 1fr;gap:10px;align-items:end;}
.dtval{background:var(--atg-gold-pale);border:1.5px solid rgba(200,150,10,.35);border-radius:8px;padding:9px 11px;font-size:13px;font-weight:600;color:var(--atg-navy);display:flex;align-items:center;gap:6px;}

/* CITY */
.city-sel{display:flex;gap:8px;margin-bottom:16px;}
.cbtn{flex:1;padding:11px 8px;border:2px solid var(--atg-border);border-radius:var(--r);background:#fff;cursor:pointer;text-align:center;transition:all .2s;font-family:inherit;}
.cbtn .cn{font-size:14px;font-weight:700;color:var(--atg-text);}
.cbtn .ce{font-size:10px;color:var(--atg-muted);margin-top:2px;}
.cbtn.sel{border-color:var(--atg-gold);background:var(--atg-gold-pale);}
.cbtn.sel .cn{color:var(--atg-navy);}

/* LOCATION */
.loc-box{background:var(--atg-off);border:1.5px solid var(--atg-border);border-radius:8px;padding:12px;}
.loc-btn{width:100%;padding:11px;background:var(--atg-navy);border:none;border-radius:8px;color:#fff;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-family:inherit;transition:all .2s;margin-bottom:10px;}
.loc-btn:hover{background:var(--atg-blue);}
.loc-btn:active{transform:scale(.97);}
.loc-result{display:none;}
.loc-result.show{display:block;}
.loc-coords{font-size:12px;color:var(--atg-muted);margin-bottom:6px;direction:ltr;text-align:left;}
.loc-link{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--atg-blue);text-decoration:none;font-weight:600;}
.loc-link:hover{text-decoration:underline;}
.loc-export-btns{display:flex;gap:6px;margin-top:8px;}
.loc-exp-btn{flex:1;padding:7px;border:1px solid var(--atg-border);border-radius:7px;background:#fff;font-size:11px;cursor:pointer;font-family:inherit;color:var(--atg-text);font-weight:500;transition:background .15s;}
.loc-exp-btn:hover{background:var(--atg-off);}
.loc-status{font-size:11px;color:var(--atg-muted);text-align:center;padding:6px 0;}

/* PHOTO */
.ph-zone{border:2px dashed var(--atg-border);border-radius:var(--r);overflow:hidden;}
.ph-btns{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.ph-btn{padding:16px 10px;border:none;background:transparent;cursor:pointer;font-family:inherit;display:flex;flex-direction:column;align-items:center;gap:6px;transition:background .15s;position:relative;}
.ph-btn:first-child{border-left:2px dashed var(--atg-border);}
[dir=ltr] .ph-btn:first-child{border-left:none;border-right:2px dashed var(--atg-border);}
.ph-btn:hover{background:var(--atg-gold-pale);}
.ph-btn input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.ph-icon{font-size:24px;}
.ph-lbl{font-size:12px;font-weight:600;color:var(--atg-navy);}
.ph-sub{font-size:10px;color:var(--atg-muted);}
.ph-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:10px;}
.ph-thumb{position:relative;aspect-ratio:1;border-radius:7px;overflow:hidden;border:1px solid var(--atg-border);}
.ph-thumb img{width:100%;height:100%;object-fit:cover;}
.ph-del{position:absolute;top:3px;left:3px;width:20px;height:20px;background:rgba(185,28,28,.85);border-radius:50%;border:none;color:#fff;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;}

/* RATING */
.rrow{display:flex;gap:5px;}
.rb{flex:1;padding:8px 3px;border:1.5px solid var(--atg-border);border-radius:8px;background:#fff;font-size:11px;cursor:pointer;text-align:center;transition:all .15s;color:var(--atg-muted);font-family:inherit;font-weight:600;}
.rb:hover{background:var(--atg-off);}
.rb.s1,.rb.s2{background:var(--atg-err-bg);border-color:#e87272;color:var(--atg-err);}
.rb.s3{background:#fffbeb;border-color:#f5c842;color:#92590a;}
.rb.s4,.rb.s5{background:var(--atg-ok-bg);border-color:#4caf8a;color:var(--atg-ok);}

/* CHECKS */
.cl{display:flex;flex-direction:column;gap:6px;}
.ci2{display:flex;align-items:center;gap:9px;padding:8px 11px;border:1px solid var(--atg-border);border-radius:8px;cursor:pointer;transition:background .12s;font-size:13px;color:var(--atg-text);}
.ci2:hover{background:var(--atg-off);}
.ci2 input[type=checkbox]{width:15px;height:15px;accent-color:var(--atg-gold);cursor:pointer;flex-shrink:0;}
.ci2.chk{background:var(--atg-gold-pale);border-color:rgba(200,150,10,.4);}

/* TAGS */
.tw{display:flex;flex-wrap:wrap;gap:5px;padding:7px 10px;border:1.5px solid var(--atg-border);border-radius:8px;min-height:42px;background:#fff;cursor:text;transition:border-color .15s;}
.tw:focus-within{border-color:var(--atg-gold);box-shadow:0 0 0 3px rgba(200,150,10,.12);}
.tg{display:flex;align-items:center;gap:3px;background:var(--atg-navy);color:var(--atg-gold-light);font-size:11px;padding:3px 8px;border-radius:20px;font-weight:600;}
.tg button{background:none;border:none;cursor:pointer;color:var(--atg-gold-light);font-size:13px;padding:0;line-height:1;}
.ti{border:none;outline:none;font-size:12px;background:transparent;color:var(--atg-text);font-family:inherit;min-width:80px;flex:1;direction:inherit;}
.th{font-size:10px;color:var(--atg-muted);margin-top:3px;}

/* INFO BOX */
.ib{background:rgba(200,150,10,.08);border:1px solid rgba(200,150,10,.3);border-radius:8px;padding:9px 13px;font-size:12px;color:var(--atg-blue);line-height:1.6;margin-bottom:13px;}

/* CONTACT BLOCK */
.contact-block{border-radius:8px;padding:11px 13px;margin-bottom:12px;}
.cb-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:9px;}

/* NAV */
.fnav{display:flex;justify-content:space-between;align-items:center;padding:14px 0 0;border-top:1px solid var(--atg-border);margin-top:6px;}
.ni{font-size:11px;color:var(--atg-muted);}
.nbtns{display:flex;gap:8px;}
.btn{padding:9px 20px;border-radius:8px;font-size:13px;font-family:inherit;cursor:pointer;font-weight:600;transition:all .15s;border:none;}
.bg{background:transparent;border:1.5px solid var(--atg-border);color:var(--atg-text);}
.bg:hover{background:var(--atg-off);}
.bp{background:var(--atg-gold);color:var(--atg-dark);}
.bp:hover{background:var(--atg-gold-light);}
.bp:active{transform:scale(.97);}
.bn{background:var(--atg-navy);color:#fff;}
.bn:hover{background:var(--atg-blue);}
.bk{background:var(--atg-ok);color:#fff;}
.bk:hover{background:#0a5a3c;}

/* RECORDS */
.rbar{background:#fff;border:1px solid var(--atg-border);border-radius:var(--r);padding:13px 16px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;box-shadow:var(--sh);}
.rc{font-size:12px;color:var(--atg-muted);}
.rc strong{color:var(--atg-navy);font-size:17px;}
.ri{background:#fff;border:1px solid var(--atg-border);border-radius:var(--r);padding:12px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--sh);cursor:pointer;transition:border-color .15s;}
.ri:hover{border-color:var(--atg-gold);}
.rcb{padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;background:var(--atg-navy);color:var(--atg-gold-light);flex-shrink:0;}
.rinfo{flex:1;min-width:0;}
.rname{font-size:13px;font-weight:600;color:var(--atg-navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rmeta{font-size:11px;color:var(--atg-muted);margin-top:2px;}
.rscore{font-size:12px;font-weight:700;padding:3px 9px;border-radius:20px;flex-shrink:0;}
.sh{background:var(--atg-ok-bg);color:var(--atg-ok);}
.sm{background:#fffbeb;color:#92590a;}
.sl{background:var(--atg-err-bg);color:var(--atg-err);}
.rdel{width:26px;height:26px;border-radius:6px;background:var(--atg-err-bg);border:none;color:var(--atg-err);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.divider{height:1px;background:var(--atg-border);margin:13px 0;}

/* SUCCESS */
.sw{text-align:center;padding:28px 16px;}
.sic{width:60px;height:60px;background:var(--atg-ok-bg);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:26px;}
.sw h2{font-size:19px;font-weight:700;color:var(--atg-navy);margin-bottom:5px;}
.sw p{font-size:13px;color:var(--atg-muted);line-height:1.6;}
.sa{display:flex;gap:8px;justify-content:center;margin-top:18px;flex-wrap:wrap;}

/* EMPTY */
.empty{text-align:center;padding:36px 20px;color:var(--atg-muted);font-size:13px;}
.empty .ei{font-size:34px;margin-bottom:9px;}

/* VIEWS */
.vw{display:none;}
.vw.active{display:block;}

/* FOOTER */
.foot{text-align:center;padding:14px;font-size:10px;color:var(--atg-muted);border-top:1px solid var(--atg-border);margin-top:6px;}

@media(max-width:500px){
.fr,.fr3{grid-template-columns:1fr;}
.dtrow{grid-template-columns:1fr 1fr;}
.slbl{display:none;}
.ph-btns{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>

<header class="hdr">
<div class="hdr-in">
  <div class="logo">
    <div class="lmark">ATG</div>
    <div><div class="lname">Advanced Trading Gateways</div><div class="ltag" id="hdr-tagline">FMCG Distribution · Oman</div></div>
  </div>
  <div class="hdr-right">
    <div class="lang-btns">
      <button class="lb active" onclick="setLang('fa')">FA</button>
      <button class="lb" onclick="setLang('ar')">AR</button>
      <button class="lb" onclick="setLang('en')">EN</button>
    </div>
    <div class="hbadge" id="hdr-badge">میدانی</div>
  </div>
</div>
</header>

<main class="main">

<!-- VIEW: HOME -->
<div class="vw active" id="view-home">
  <div class="rbar">
    <div class="rc"><strong id="rec-count">0</strong> <span id="t-records">گزارش ثبت‌شده</span></div>
    <div style="display:flex;gap:7px;">
      <button class="btn bk" onclick="exportExcel()" id="t-btn-excel">📊 اکسل</button>
      <button class="btn bp" onclick="exportGeoJSON()" id="t-btn-geo">📍 GeoJSON</button>
      <button class="btn bn" onclick="startNew()" id="t-btn-new">+ بازدید</button>
    </div>
  </div>
  <div id="records-list">
    <div class="empty"><div class="ei">📋</div><span id="t-empty">هنوز بازدیدی ثبت نشده.</span></div>
  </div>
</div>

<!-- VIEW: FORM -->
<div class="vw" id="view-form">
  <div class="sbar" id="step-bar">
    <div class="si active" data-s="1" onclick="goStep(1)"><div class="snum">1</div><div class="slbl" id="sl1">مکان</div></div>
    <div class="si" data-s="2" onclick="goStep(2)"><div class="snum">2</div><div class="slbl" id="sl2">تماس</div></div>
    <div class="si" data-s="3" onclick="goStep(3)"><div class="snum">3</div><div class="slbl" id="sl3">بازار</div></div>
    <div class="si" data-s="4" onclick="goStep(4)"><div class="snum">4</div><div class="slbl" id="sl4">تامین</div></div>
    <div class="si" data-s="5" onclick="goStep(5)"><div class="snum">5</div><div class="slbl" id="sl5">فرصت</div></div>
    <div class="si" data-s="6" onclick="goStep(6)"><div class="snum">6</div><div class="slbl" id="sl6">نتیجه</div></div>
  </div>

  <!-- S1: Location + Photos -->
  <div id="s1">
    <div class="card">
      <div class="ch"><div class="ci">📍</div><div><div class="ct" id="t-s1-title">اطلاعات پایه</div><div class="cs" id="t-s1-sub">شهر · زمان · موقعیت</div></div></div>
      <div class="cb">
        <div class="f" id="t-city-label-wrap"><label id="t-city-label">شهر <span class="req">*</span></label>
          <select id="city-select" onchange="selCityDrop(this.value)" style="width:100%;padding:9px 11px;border:1.5px solid var(--atg-border);border-radius:8px;font-size:13px;color:var(--atg-text);background:#fff;font-family:inherit;outline:none;cursor:pointer">
            <option value="muscat">مسقط — Muscat</option>
            <option value="seeb">سیب — Seeb</option>
            <option value="nizwa" selected>نزوی — Nizwa</option>
            <option value="sohar">صحار — Sohar</option>
            <option value="salalah">صلاله — Salalah</option>
            <option value="sur">صور — Sur</option>
            <option value="barka">بارکا — Barka</option>
            <option value="rustaq">رستاق — Rustaq</option>
            <option value="bahla">بهلاء — Bahla</option>
            <option value="ibri">عبری — Ibri</option>
            <option value="izki">ایزکی — Izki</option>
            <option value="samail">سمائل — Samail</option>
            <option value="suwaiq">السویق — Al Suwaiq</option>
            <option value="saham">سهام — Saham</option>
            <option value="khasab">خصب — Khasab</option>
            <option value="duqm">الدقم — Duqm</option>
            <option value="haima">هیما — Haima</option>
            <option value="ibra">ابراء — Ibra</option>
            <option value="sinaw">سناو — Sinaw</option>
            <option value="other">سایر — Other</option>
          </select>
        </div>
        <div class="f" id="district-wrap">
          <label id="t-district-label">محله / منطقه شهر</label>
          <select id="district-select" onchange="upd_district(this.value)" style="width:100%;padding:9px 11px;border:1.5px solid var(--atg-border);border-radius:8px;font-size:13px;color:var(--atg-text);background:#fff;font-family:inherit;outline:none;cursor:pointer">
