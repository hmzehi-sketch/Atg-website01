// ── LANG ──
function setLang(l) {
  lang = l;
  const t = T[l];
  document.body.setAttribute("dir", t.dir);
  document.documentElement.setAttribute("lang", t.lang);
  document.querySelectorAll(".lb").forEach(b => b.classList.toggle("active", b.textContent.trim() === l.toUpperCase()));
  Object.entries(t).forEach(([k, v]) => {
    if (k === "dir" || k === "lang") return;
    const el = document.getElementById(k);
    if (!el) return;
    if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
      el.placeholder = v;
    } else if (el.tagName === "LABEL") {
      const req = el.querySelector(".req");
      el.textContent = v;
      if (req) el.appendChild(req);
    } else {
      el.textContent = v;
    }
  });
  // placeholders via data-t
  document.querySelectorAll("[data-t]").forEach(el => {
    const key = el.dataset.t;
    if (t[key]) el.placeholder = t[key];
  });
}

// ── CLOCK ──
function updateClock() {
  const now = new Date();
  const dateStr = now.toLocaleDateString("en-CA"); // YYYY-MM-DD
  const timeStr = now.toLocaleTimeString("en-GB", {hour:"2-digit", minute:"2-digit"});
  document.getElementById("disp-date").textContent = dateStr;
  document.getElementById("disp-time").textContent = timeStr;
}
