});

// ── GPS ──
function getLocation() {
  const btn = document.getElementById("loc-btn");
  const status = document.getElementById("loc-status");
  const t = T[lang];
  status.textContent = t["loc-searching"];
  btn.disabled = true;
  if (!navigator.geolocation) { status.textContent = t["loc-error"]; btn.disabled = false; return; }
  navigator.geolocation.getCurrentPosition(pos => {
    const lat = pos.coords.latitude.toFixed(6);
    const lng = pos.coords.longitude.toFixed(6);
    const acc = Math.round(pos.coords.accuracy);
    gpsData = { lat, lng, acc };
    const gmapUrl = "https://www.google.com/maps?q=" + lat + "," + lng;
    document.getElementById("loc-coords").textContent = lat + ", " + lng + "  (±" + acc + "m)";
    const link = document.getElementById("loc-gmap-link");
    link.href = gmapUrl;
    document.getElementById("loc-result").classList.add("show");
    status.textContent = t["loc-success"];
    btn.disabled = false;
  }, err => {
    status.textContent = t["loc-error"] + ": " + err.message;
    btn.disabled = false;
  }, {enableHighAccuracy: true, timeout: 15000});
}

function copyCoords() {
  if (!gpsData) return;
  navigator.clipboard.writeText(gpsData.lat + ", " + gpsData.lng);
