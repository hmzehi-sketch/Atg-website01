  ws["!cols"] = wc.map(w => ({wch:w}));
  XLSX.utils.book_append_sheet(wb, ws, "Visits");
  // Summary sheet
  const niz = records.filter(r => r.city.includes("نزوی") || r.city.includes("نزوى") || r.city === "Nizwa");
  const soh = records.filter(r => r.city.includes("صحار") || r.city === "Sohar / صحار");
  const avgS = arr => arr.length ? (arr.reduce((s,r)=>s+(+r.marketScore||0),0)/arr.length).toFixed(1) : "—";
  const sumData = [
    ["ATG Field Research — Summary","",""],["Advanced Trading Gateways · atgco.om","",""],["","",""],
    ["Metric","Nizwa","Sohar"],
    ["Total Visits", niz.length, soh.length],
    ["Avg Market Score", avgS(niz), avgS(soh)],
    ["High Score (4+)", niz.filter(r=>(+r.marketScore||0)>=4).length, soh.filter(r=>(+r.marketScore||0)>=4).length],
    ["","",""],["Next Steps","Count",""],
    ...Object.entries(records.reduce((a,r)=>{if(r.nextStep){a[r.nextStep]=(a[r.nextStep]||0)+1;}return a;},{})).map(([k,v])=>[k,v,""])
  ];
  const ws2 = XLSX.utils.aoa_to_sheet(sumData);
  ws2["!cols"] = [{wch:35},{wch:12},{wch:12}];
  XLSX.utils.book_append_sheet(wb, ws2, "Summary");
  const d = new Date().toISOString().slice(0,10);
  XLSX.writeFile(wb, "ATG_FieldResearch_" + d + ".xlsx");
}

// ── GEOJSON ──
function exportGeoJSON() {
  const hasGps = records.filter(r => r.lat && r.lng);
  if (!hasGps.length) { alert(lang === "en" ? "No GPS records" : "لا توجد إحداثيات / موقعیتی ثبت نشده"); return; }
  const gj = {
    type: "FeatureCollection",
    features: hasGps.map(r => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [parseFloat(r.lng), parseFloat(r.lat)] },
      properties: {
        name: r.company, city: r.city, type: r.type, date: r.date,
        owner: r.ownerName, ownerPhone: r.ownerPhone,
        buyer: r.buyerName, buyerPhone: r.buyerPhone,
        marketScore: r.marketScore, readiness: r.readiness,
        nextStep: r.nextStep, agent: r.agent,
        googleMaps: r.gmapLink
      }
    }))
  };
  const blob = new Blob([JSON.stringify(gj, null, 2)], {type: "application/json"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "ATG_Locations_" + new Date().toISOString().slice(0,10) + ".geojson";
  a.click();
}

